# ===========================
# App / Server Runtime
# ===========================
# HOST: Bind address for API server
HOST=0.0.0.0

# PORT: HTTP port for API server (run.py reads PORT/API_PORT)
PORT=8001

# DISABLE_AUTO_LOGGING_CONFIG: Internal switch to keep custom logging behavior
DISABLE_AUTO_LOGGING_CONFIG=1

# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default recommended for production: ERROR
LOG_LEVEL=ERROR

# ===========================
# STT / Whisper
# ===========================
# Runtime-managed critical values; leave empty unless explicit bootstrap is needed
# STT_SIGN: Signature for upstream STT submit request
STT_SIGN=

# STT_X_TT_TOKEN: Token header value required by upstream STT service
STT_X_TT_TOKEN=

# STT_COOKIE: Cookie string for upstream STT authentication/session
STT_COOKIE=

# STT_QUERY_SIGN: Signature for upstream STT query request
STT_QUERY_SIGN=

# FASTER_WHISPER_MODEL: tiny/base/small/medium/large-v3/large-v* (depends on hardware)
FASTER_WHISPER_MODEL=medium

# FASTER_WHISPER_DEVICE: cpu/cuda
FASTER_WHISPER_DEVICE=cpu

# FASTER_WHISPER_COMPUTE_TYPE: int8, int8_float16, float16, float32...
FASTER_WHISPER_COMPUTE_TYPE=int8

# FASTER_WHISPER_BEAM_SIZE: Beam search width for transcription quality/speed tradeoff
FASTER_WHISPER_BEAM_SIZE=4

# FASTER_WHISPER_VAD_FILTER: Enable VAD filtering for long/noisy audio
FASTER_WHISPER_VAD_FILTER=false

# FASTER_WHISPER_TEMP_DIR: Temporary working directory for STT artifacts
FASTER_WHISPER_TEMP_DIR=./tmp_files/stt_whisper

# FASTER_WHISPER_CPU_THREADS: Number of CPU threads for Whisper processing
FASTER_WHISPER_CPU_THREADS=10

# FASTER_WHISPER_BATCH_SIZE: Number of audio segments processed in a single batch
FASTER_WHISPER_BATCH_SIZE=10

# Enable/disable audio normalization during audio extraction for Whisper
# When true, ffmpeg will run a normalization filter before saving the WAV.
FASTER_WHISPER_NORMALIZE=false

# Choose normalization filter: "loudnorm" (EBU R128) or "dynaudnorm" (dynamic).
# Valid values: "loudnorm", "dynaudnorm". Default: loudnorm.
FASTER_WHISPER_NORMALIZE_FILTER=dynaudnorm

# ===========================
# FFmpeg Core
# ===========================
# FFMPEG_VIDEO_CRF: CPU x264 quality factor (0-51, lower = better quality)
FFMPEG_VIDEO_CRF=30

# FFMPEG_VIDEO_PRESET_GPU: Preset used for GPU-capable paths when preset is supported
FFMPEG_VIDEO_PRESET_GPU=medium

# FFMPEG_VIDEO_PRESET_CPU: x264 preset (ultrafast...veryslow)
FFMPEG_VIDEO_PRESET_CPU=medium

# FFMPEG_ENABLE_B_FRAMES: Toggle B-frames for CPU encode paths
FFMPEG_ENABLE_B_FRAMES=true

# FFMPEG_HWACCEL: Enable hardware decode acceleration when possible
FFMPEG_HWACCEL=true

# FFMPEG_FILTER_THREADS: auto or fixed thread number for filter graph
FFMPEG_FILTER_THREADS=auto

# FFMPEG_VIDEO_SCALE_WIDTH: Target width for downscale-only filter, 0 disables scaling
FFMPEG_VIDEO_SCALE_WIDTH=0

# FFMPEG_PROGRESS_TRACKING: Enable ffmpeg progress pipe output
FFMPEG_PROGRESS_TRACKING=true

# GPU/NVENC controls
# FFMPEG_NVENC_CQ: NVENC constant quality target (lower = better)
FFMPEG_NVENC_CQ=30

# FFMPEG_GPU_MAXRATE_MBPS: Optional NVENC maxrate cap (0 disables)
FFMPEG_GPU_MAXRATE_MBPS=8

# FFMPEG_GPU_BUFSIZE_MBPS: Optional NVENC VBV buffer size (0 auto)
FFMPEG_GPU_BUFSIZE_MBPS=16

# FFMPEG_DISABLE_NVENC: Force disable NVENC path even if encoder is listed
FFMPEG_DISABLE_NVENC=true

# FFMPEG_REQUIRE_GPU: If true and use_gpu=true, fail instead of CPU fallback
FFMPEG_REQUIRE_GPU=true

# AMD AMF quality profile
# FFMPEG_ALLOW_AMF_ENCODING: Allow AMD AMF encode path
FFMPEG_ALLOW_AMF_ENCODING=true

# FFMPEG_AMF_USAGE: transcoding, ultralowlatency, lowlatency, webcam,
# high_quality, lowlatency_high_quality
FFMPEG_AMF_USAGE=high_quality

# FFMPEG_AMF_QUALITY: speed, balanced, quality
FFMPEG_AMF_QUALITY=quality

# FFMPEG_AMF_RC: cqp, cbr, vbr_peak, vbr_latency, qvbr, hqvbr, hqcbr
FFMPEG_AMF_RC=hqvbr

# FFMPEG_AMF_QVBR_QUALITY_LEVEL: 0-51, lower = better quality
FFMPEG_AMF_QVBR_QUALITY_LEVEL=20

# FFMPEG_AMF_MAXRATE_MBPS: Optional AMF maxrate cap (0 disables)
FFMPEG_AMF_MAXRATE_MBPS=0

# FFMPEG_AMF_BUFSIZE_MBPS: Optional AMF buffer size (0 auto/disabled)
FFMPEG_AMF_BUFSIZE_MBPS=0

# FFMPEG_AMF_PROFILE: main, high, constrained_baseline, constrained_high
FFMPEG_AMF_PROFILE=high

# FFMPEG_AMF_B_FRAMES: Consecutive B-frame count (0-3)
FFMPEG_AMF_B_FRAMES=2

# FFMPEG_AMF_VBAQ: Enable AMF VBAQ for perceptual quality retention
FFMPEG_AMF_VBAQ=true

# Audio encoding
# FFMPEG_AUDIO_BITRATE_KBPS: Output audio bitrate for regular flows
FFMPEG_AUDIO_BITRATE_KBPS=128

# FFMPEG_AUDIO_SAMPLE_RATE: Output sample rate for regular flows
FFMPEG_AUDIO_SAMPLE_RATE=48000

# FFMPEG_TTS_AUDIO_BITRATE_KBPS: Output bitrate for TTS merge flows
FFMPEG_TTS_AUDIO_BITRATE_KBPS=256

# FFMPEG_TTS_SAMPLE_RATE: Output sample rate for TTS merge flows
FFMPEG_TTS_SAMPLE_RATE=48000

# FFMPEG_IMAGE_AUDIO_MERGE_TIMEOUT_SEC: Timeout for image+audio ffmpeg merge job
FFMPEG_IMAGE_AUDIO_MERGE_TIMEOUT_SEC=120